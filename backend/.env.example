# Firebase Configuration (from Firebase Console -> Project Settings)
# 1. Go to https://console.firebase.google.com/
# 2. Select your project
# 3. Go to Project Settings
# 4. Service Accounts -> Click "Generate new private key"
# 5. Copy the entire JSON and stringify it for FIREBASE_CONFIG
FIREBASE_CONFIG='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Email Configuration (for low stock alerts)
# Using Gmail:
# 1. Enable 2FA on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password below
ALERT_EMAIL=your-email@gmail.com
ALERT_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Alternative: Use your own email service
# ALERT_EMAIL_SERVICE=your-email-service
# ALERT_EMAIL_HOST=smtp.your-service.com
# ALERT_EMAIL_PORT=587
# ALERT_EMAIL_USER=your-email@example.com
# ALERT_EMAIL_PASSWORD=your-password
